# .env.example

# Application
PORT=4000
NODE_ENV=development

# Postgres
DATABASE_URL=postgres://user:pass@localhost:5432/eims_db
PGSSLMODE=prefer

# JWT
JWT_SECRET=replace_with_secure_random_value
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# Storage
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_BYTES=20000000

# Email/SMS placeholders
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=username
SMTP_PASS=password
SMS_PROVIDER_API_KEY=

# Other
SENTRY_DSN=
